# Flask secret configuration
SECRET_KEY=sentinelshield-super-secret-key-change-me
JWT_SECRET=sentinelshield-jwt-secret-key-change-me

# SMTP Gmail alerting configurations (Gmail credentials)
# Triggered when risk_score >= 85
ALERT_EMAIL_SENDER=your-sender-email@gmail.com
ALERT_EMAIL_PASSWORD=your-gmail-app-password
ALERT_EMAIL_RECEIVER=your-receiver-email@gmail.com

# Threat intelligence APIs
# Used to verify IP reputation
ABUSEIPDB_API_KEY=your-abuseipdb-api-key-here
